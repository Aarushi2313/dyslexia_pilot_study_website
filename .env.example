SECRET_KEY=replace_with_a_long_random_secret

# Database
MYSQLHOST=localhost
MYSQLUSER=root
MYSQLPASSWORD=replace_with_db_password
MYSQLDATABASE=aviendbnew
MYSQLPORT=3306

# OTP policy
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Sender mailbox used for OTP emails
MAIL_SENDER_EMAIL=your-sender@gmail.com

# Gmail OAuth2 credentials for SMTP XOAUTH2
# 1) Create OAuth client in Google Cloud
# 2) Generate refresh token for the sender mailbox with Gmail scope
GOOGLE_MAIL_CLIENT_ID=your_google_oauth_client_id
GOOGLE_MAIL_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_MAIL_REFRESH_TOKEN=your_google_oauth_refresh_token

# Existing Google Sign-In configuration (already used elsewhere in app)
GOOGLE_CLIENT_ID=your_google_signin_client_id
GOOGLE_CLIENT_SECRET=your_google_signin_client_secret
GOOGLE_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration
